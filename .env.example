# ScoutBet — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── API-Football (api-sports.io) ─────────────────────────────────────────────
# Get your key at: https://dashboard.api-football.com/register
VITE_API_FOOTBALL_KEY=

# ── Mock mode ────────────────────────────────────────────────────────────────
# Set to "true" to use mock data regardless of API key (useful for UI work)
VITE_USE_MOCK=false

# ── Football season ──────────────────────────────────────────────────────────
# Current season year (2024 = 2024/25 season)
VITE_FOOTBALL_SEASON=2024

# ── Watched leagues ───────────────────────────────────────────────────────────
# Comma-separated league IDs. Defaults cover the 8 top European competitions.
# 2=UCL  3=UEL  39=PremierLeague  140=LaLiga  78=Bundesliga  135=SerieA
# 61=Ligue1  94=PrimeiraLiga
VITE_WATCHED_LEAGUES=2,3,39,140,78,135,61,94
